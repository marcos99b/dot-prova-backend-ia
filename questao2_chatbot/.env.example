# Provedor do LLM. Padrão: openai (conforme o enunciado).
# Opções: openai | groq | anthropic | fake
LLM_PROVIDER=openai

# Modelo (opcional). Se vazio, usa o padrão de cada provedor.
# openai -> gpt-4o-mini | groq -> llama-3.3-70b-versatile | anthropic -> claude-3-5-sonnet-latest
LLM_MODEL=

# Criatividade da resposta (0.0 = determinístico, 1.0 = mais livre).
LLM_TEMPERATURE=0.3

# ---- Chaves de API (preencha conforme o provedor escolhido) ----
# Para LLM_PROVIDER=openai:
OPENAI_API_KEY=

# Para LLM_PROVIDER=groq (free tier em https://console.groq.com):
# GROQ_API_KEY=

# Para LLM_PROVIDER=anthropic:
# ANTHROPIC_API_KEY=
